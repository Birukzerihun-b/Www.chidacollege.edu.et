{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student registration record.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the student." },
        "fullName": { "type": "string", "description": "Full name of the student." },
        "email": { "type": "string", "description": "Email address of the student." },
        "phone": { "type": "string", "description": "Phone number of the student." },
        "department": { "type": "string", "description": "Department the student is applying for." },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Registration status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the registration was created." },
        "uid": { "type": "string", "description": "The Firebase Auth UID of the student (if logged in)." }
      },
      "required": ["fullName", "email", "phone", "department", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user profile (admin or student).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "email": { "type": "string", "description": "User email." },
        "role": { "type": "string", "enum": ["admin", "student"], "description": "User role." },
        "displayName": { "type": "string", "description": "User display name." }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/registrations/{registrationId}": {
      "schema": "Student",
      "description": "Collection of student registrations."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    }
  }
}
